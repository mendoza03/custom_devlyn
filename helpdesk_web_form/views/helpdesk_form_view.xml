<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="helpdesk_form_template">
        <t t-call="website.layout">
            <div class="container mt-5">

                <h3>Datos generales</h3>

                <form action="/helpdesk/submit" method="post" enctype="multipart/form-data" class="row g-3">

                    <!-- Descripción General -->
                    <div class="col-12">
                        <label>Descripción General (*)</label>
                        <input type="text" name="x_general_description" class="form-control" required="1"/>
                    </div>

                    <!-- Sección -->
                    <div class="col-12">
                        <label>Sección (*)</label>
                        <select name="x_section_id" id="section" class="form-select">
                            <option value="">-- seleccionar --</option>
                            <t t-foreach="sections" t-as="s">
                                <option t-att-value="s.id"><t t-esc="s.name"/></option>
                            </t>
                        </select>
                    </div>

                    <!-- Categoría -->
                    <div class="col-md-6">
                        <label>Categoría (*)</label>
                        <select name="x_category_id" id="category" class="form-select">
                            <option value="">-- seleccionar --</option>
                        </select>
                    </div>

                    <!-- Subcategoría -->
                    <div class="col-md-6">
                        <label>Subcategoría (*)</label>
                        <select name="x_subcategory_id" id="subcategory" class="form-select">
                            <option value="">-- seleccionar --</option>
                        </select>
                    </div>

                    <!-- Descripción Detallada -->
                    <div class="col-12">
                        <label>Descripción Detallada</label>
                        <textarea name="x_detailed_description" class="form-control o_wysiwyg"/>
                    </div>

                    <!-- ===== BLOQUE: Micas sin cortar ===== -->
                    <div id="micas-sin-cortar-block" class="col-12 row g-3" style="display:none;">
                    <div class="col-12 mt-4">
                        <h5 class="border-bottom pb-2">Micas sin cortar</h5>
                    </div>

                    <!-- Pedido -->
                    <div class="col-md-6">
                        <label>Pedido</label>
                        <input type="text" name="x_order_number" class="form-control"/>
                    </div>

                    <!-- Bolsa -->
                    <div class="col-md-6">
                        <label>Bolsa</label>
                        <input type="text" name="x_bag" class="form-control"/>
                    </div>

                    <!-- Armazón del cliente -->
                    <div class="col-md-6">
                        <label>Armazón del cliente?</label>
                        <select name="x_customer_warehouse" class="form-select">
                            <option value="select">-- seleccionar --</option>
                            <option value="si">Sí</option>
                            <option value="no">No</option>
                        </select>
                    </div>

                    <!-- Tipo de pedido -->
                    <div class="col-md-6">
                        <label>Tipo de pedido</label>
                        <select name="x_order_type" class="form-select">
                            <option value="select">-- seleccionar --</option>
                            <option value="retallado">Retallado</option>
                            <option value="garantia_calidad">Garantía de calidad</option>
                            <option value="satisfaccion_adaptacion">Satisfacción total de adaptación</option>
                            <option value="satisfaccion_imagen">Satisfacción total de imagen</option>
                            <option value="captura_primera_vez">Captura primera vez</option>
                        </select>
                    </div>

                    <!-- Persona que Autoriza -->
                    <div class="col-md-6">
                        <label>Persona que Autoriza</label>
                        <input type="text" name="x_authorized_by" class="form-control"/>
                    </div>

                    <!-- LAB indicado -->
                    <div class="col-md-6">
                        <label>LAB indicado en portal de seguimiento de trabajos</label>
                        <input type="text" name="x_lab_indicated" class="form-control"/>
                    </div>
                    </div><!-- ===== FIN BLOQUE Micas sin cortar ===== -->

                    <!-- Adjuntos -->
                    <div class="col-12 mt-2">
                        <label>Adjuntar archivos</label>
                        <input type="file" name="attachments" multiple="multiple" class="form-control"/>
                    </div>

                    <div class="col-12 mt-3 mb-3">
                        <button type="submit" class="btn btn-primary">
                            Enviar Ticket
                        </button>
                    </div>

                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                </form>
            </div>
            <script type="text/javascript" src="/helpdesk_web_form/static/src/js/index.js"></script>
        </t>
    </template>
</odoo>
