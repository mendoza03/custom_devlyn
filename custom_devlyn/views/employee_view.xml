<odoo>
    <record id="view_hr_employee_form_inherit_employee_number" model="ir.ui.view">
        <field name="name">hr.employee.form.employee.number</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//page[1]//group[1]" position="inside">
                <field name="employee_number"/>
            </xpath>
        </field>
    </record>

</odoo>
