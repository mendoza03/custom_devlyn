<odoo>
    <record id="view_biometric_auth_event_list" model="ir.ui.view">
        <field name="name">biometric.auth.event.list</field>
        <field name="model">biometric.auth.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="event_type"/>
                <field name="result"/>
                <field name="auth_channel"/>
                <field name="login"/>
                <field name="attendance_action"/>
                <field name="attendance_status"/>
                <field name="attendance_id"/>
                <field name="country"/>
                <field name="city"/>
                <field name="asn"/>
                <field name="liveness_score"/>
                <field name="face_match_similarity"/>
                <field name="face_match_request_id"/>
                <field name="rekognition_session_id"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_auth_event_form" model="ir.ui.view">
        <field name="name">biometric.auth.event.form</field>
        <field name="model">biometric.auth.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="event_type"/>
                        <field name="result"/>
                        <field name="reason"/>
                        <field name="flow_mode"/>
                        <field name="auth_channel"/>
                        <field name="login"/>
                        <field name="user_id"/>
                        <field name="attendance_action"/>
                        <field name="attendance_status"/>
                        <field name="attendance_id"/>
                        <field name="liveness_score"/>
                        <field name="liveness_provider"/>
                        <field name="liveness_passed"/>
                        <field name="face_match_attempted"/>
                        <field name="face_match_passed"/>
                        <field name="face_match_similarity"/>
                        <field name="face_match_reason"/>
                        <field name="face_match_request_id"/>
                        <field name="rekognition_session_id"/>
                        <field name="s3_video_url" widget="url"/>
                        <field name="auto_close_applied"/>
                        <field name="auto_close_reason"/>
                        <field name="auto_closed_attendance_id"/>
                    </group>
                    <group string="Connection">
                        <field name="ip_public"/>
                        <field name="x_forwarded_for"/>
                        <field name="country"/>
                        <field name="city"/>
                        <field name="asn"/>
                        <field name="isp"/>
                        <field name="lat"/>
                        <field name="lon"/>
                        <field name="accuracy"/>
                    </group>
                    <group string="Device">
                        <field name="browser"/>
                        <field name="os"/>
                        <field name="device_type"/>
                        <field name="network_type"/>
                        <field name="downlink"/>
                        <field name="rtt"/>
                        <field name="user_agent"/>
                    </group>
                    <group string="Raw">
                        <field name="raw_payload" widget="json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_biometric_auth_event" model="ir.actions.act_window">
        <field name="name">Biometric Events</field>
        <field name="res_model">biometric.auth.event</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
