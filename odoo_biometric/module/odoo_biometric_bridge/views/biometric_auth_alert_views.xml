<odoo>
    <record id="view_biometric_auth_alert_list" model="ir.ui.view">
        <field name="name">biometric.auth.alert.list</field>
        <field name="model">biometric.auth.alert</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="severity"/>
                <field name="code"/>
                <field name="user_id"/>
                <field name="resolved"/>
            </list>
        </field>
    </record>

    <record id="view_biometric_auth_alert_form" model="ir.ui.view">
        <field name="name">biometric.auth.alert.form</field>
        <field name="model">biometric.auth.alert</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="severity"/>
                        <field name="code"/>
                        <field name="user_id"/>
                        <field name="event_id"/>
                        <field name="resolved"/>
                        <field name="resolved_by"/>
                        <field name="resolved_at"/>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_resolve" type="object" string="Resolve" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_biometric_auth_alert" model="ir.actions.act_window">
        <field name="name">Biometric Alerts</field>
        <field name="res_model">biometric.auth.alert</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
