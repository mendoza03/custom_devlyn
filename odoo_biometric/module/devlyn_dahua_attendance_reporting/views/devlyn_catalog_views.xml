    <record id="view_devlyn_catalog_branch_search" model="ir.ui.view">
        <field name="name">devlyn.catalog.branch.search</field>
        <field name="model">devlyn.catalog.branch</field>
        <field name="arch" type="xml">
            <search>
                <field name="center_code"/>
                <field name="branch_code"/>
                <field name="branch_name"/>
                <field name="region_id"/>
                <field name="zone_id"/>
                <field name="district_id"/>
                <field name="format_id"/>
                <field name="status_id"/>
                <field name="optical_level_id"/>
                <filter name="active" string="Activas" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivas" domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="group_region" string="Región" context="{'group_by': 'region_id'}"/>
                <filter name="group_zone" string="Zona" context="{'group_by': 'zone_id'}"/>
                <filter name="group_district" string="Distrito" context="{'group_by': 'district_id'}"/>
                <filter name="group_format" string="Formato" context="{'group_by': 'format_id'}"/>
                <filter name="group_status" string="Estatus" context="{'group_by': 'status_id'}"/>
            </search>
        </field>
    </record>

