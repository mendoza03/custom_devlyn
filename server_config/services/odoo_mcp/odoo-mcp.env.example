ODOO_MCP_APP_NAME=Devlyn Odoo Attendance MCP
ODOO_MCP_APP_VERSION=1.0.0
ODOO_MCP_PUBLIC_BASE_URL=https://mcp.odootest.mvpstart.click
ODOO_MCP_MOUNT_PATH=/mcp
ODOO_MCP_HOST=127.0.0.1
ODOO_MCP_PORT=8071
ODOO_MCP_LOG_LEVEL=INFO

# Global MCP perimeter token. Deliver this same token to the operator as X-API-Key.
ODOO_MCP_API_KEY=replace-with-generated-global-mcp-token

# Backend Odoo XML-RPC credentials for the dedicated technical user.
ODOO_MCP_ODOO_URL=https://erp.odootest.mvpstart.click
ODOO_MCP_ODOO_DB=devlyn_com
ODOO_MCP_ODOO_LOGIN=mcp.readonly
ODOO_MCP_ODOO_API_KEY=replace-with-generated-odoo-api-key
ODOO_MCP_ODOO_LOCALE=es_MX
ODOO_MCP_ODOO_TIMEOUT_SECONDS=15

# Backend biometric_ingest PostgreSQL read-only credentials.
ODOO_MCP_BIOMETRIC_PG_DSN=postgresql://mcp_readonly:replace-with-password@127.0.0.1:5432/biometric_ingest
ODOO_MCP_BIOMETRIC_PG_CONNECT_TIMEOUT_SECONDS=5
ODOO_MCP_BIOMETRIC_PG_STATEMENT_TIMEOUT_MS=5000

ODOO_MCP_DEFAULT_LIMIT=50
ODOO_MCP_MAX_LIMIT=200
ODOO_MCP_DEFAULT_WINDOW_DAYS=7
ODOO_MCP_CACHE_TTL_SECONDS=300
ODOO_MCP_DEFAULT_TIMEZONE=America/Mexico_City
