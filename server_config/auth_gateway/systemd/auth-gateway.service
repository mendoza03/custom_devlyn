[Unit]
Description=Odoo Biometric Auth Gateway (FastAPI)
After=network.target

[Service]
Type=simple
User=odoo
Group=odoo
WorkingDirectory=/opt/auth-gateway
EnvironmentFile=/opt/auth-gateway/.env
ExecStart=/opt/auth-gateway/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8080 --proxy-headers
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
