<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_helpdesk_section_list" model="ir.ui.view">
        <field name="name">helpdesk.section.list</field>
        <field name="model">helpdesk.section</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_section_form" model="ir.ui.view">
        <field name="name">helpdesk.section.form</field>
        <field name="model">helpdesk.section</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_section" model="ir.actions.act_window">
        <field name="name">Secciones</field>
        <field name="res_model">helpdesk.section</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea y administra las secciones del Helpdesk.
            </p>
        </field>
    </record>
</odoo>