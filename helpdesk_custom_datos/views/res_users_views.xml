<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_users_form_helpdesk_custom_datos_branch" model="ir.ui.view">
        <field name="name">res.users.form.helpdesk.custom.datos.branch</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']//group[@name='other_preferences']" position="inside">
                <field name="x_branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_users_form_simple_modif_helpdesk_custom_datos_branch" model="ir.ui.view">
        <field name="name">res.users.preferences.form.helpdesk.custom.datos.branch</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences_page']//group[@name='other_preferences']" position="inside">
                <field name="x_branch_id"/>
            </xpath>
        </field>
    </record>

</odoo>
