<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- CATEGORY: list -->
    <record id="view_helpdesk_ticket_category_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.category.list</field>
        <field name="model">helpdesk.ticket.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- CATEGORY: form -->
    <record id="view_helpdesk_ticket_category_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.category.form</field>
        <field name="model">helpdesk.ticket.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_ticket_category" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">helpdesk.ticket.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>