<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_helpdesk_ticket_subcategory_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.subcategory.list</field>
        <field name="model">helpdesk.ticket.subcategory</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_ticket_subcategory_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.subcategory.form</field>
        <field name="model">helpdesk.ticket.subcategory</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category_id" required="1"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_ticket_subcategory" model="ir.actions.act_window">
        <field name="name">Subcategorías</field>
        <field name="res_model">helpdesk.ticket.subcategory</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>