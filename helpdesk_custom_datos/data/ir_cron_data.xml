<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_cron_helpdesk_ticket_auto_close_weekday_inactivity" model="ir.cron">
        <field name="name">Helpdesk Ticket: Close inactive tickets after 24 weekday hours</field>
        <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_close_inactive_weekday_tickets()</field>
        <field name="active" eval="True"/>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="DateTime.now().strftime('%Y-%m-%d %H:00:00')"/>
    </record>

</odoo>
